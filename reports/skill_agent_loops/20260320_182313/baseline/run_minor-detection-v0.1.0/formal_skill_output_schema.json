{
  "$defs": {
    "ConfidenceBand": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "ConfidenceBand",
      "type": "string"
    },
    "FormalDecision": {
      "properties": {
        "is_minor": {
          "description": "是否判定为未成年人",
          "title": "Is Minor",
          "type": "boolean"
        },
        "minor_confidence": {
          "description": "未成年人置信度",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Minor Confidence",
          "type": "number"
        },
        "confidence_band": {
          "$ref": "#/$defs/ConfidenceBand",
          "description": "置信度分段"
        },
        "risk_level": {
          "$ref": "#/$defs/RiskLevel",
          "description": "风险等级"
        }
      },
      "required": [
        "is_minor",
        "minor_confidence",
        "confidence_band",
        "risk_level"
      ],
      "title": "FormalDecision",
      "type": "object",
      "additionalProperties": false
    },
    "FormalEvidence": {
      "properties": {
        "direct_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Direct Evidence",
          "type": "array"
        },
        "historical_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Historical Evidence",
          "type": "array"
        },
        "retrieval_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Retrieval Evidence",
          "type": "array"
        },
        "time_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Time Evidence",
          "type": "array"
        },
        "conflicting_signals": {
          "items": {
            "type": "string"
          },
          "title": "Conflicting Signals",
          "type": "array"
        }
      },
      "title": "FormalEvidence",
      "type": "object",
      "additionalProperties": false
    },
    "FormalTrend": {
      "properties": {
        "trajectory": {
          "items": {
            "$ref": "#/$defs/TrendPoint"
          },
          "title": "Trajectory",
          "type": "array"
        },
        "trend_summary": {
          "default": "",
          "description": "趋势总结",
          "title": "Trend Summary",
          "type": "string"
        }
      },
      "title": "FormalTrend",
      "type": "object",
      "additionalProperties": false
    },
    "FormalUserProfile": {
      "properties": {
        "age_range": {
          "description": "年龄段描述",
          "title": "Age Range",
          "type": "string"
        },
        "education_stage": {
          "description": "教育阶段",
          "title": "Education Stage",
          "type": "string"
        },
        "identity_markers": {
          "description": "身份标记",
          "items": {
            "type": "string"
          },
          "title": "Identity Markers",
          "type": "array"
        }
      },
      "required": [
        "age_range",
        "education_stage"
      ],
      "title": "FormalUserProfile",
      "type": "object",
      "additionalProperties": false
    },
    "ICBOFeatures": {
      "description": "ICBO 理论框架特征\n- I (Intention): 用户意图\n- C (Cognition): 认知特征\n- B (Behavior): 语言/行为风格\n- O (Opportunity): 语义时间",
      "properties": {
        "intention": {
          "description": "用户意图：对话的核心目的，如寻求情感支持、宣泄压力、咨询问题等",
          "title": "Intention",
          "type": "string"
        },
        "cognition": {
          "description": "认知特征：用户的思维模式，如灾难化思维、非黑即白、过度概括等",
          "title": "Cognition",
          "type": "string"
        },
        "behavior_style": {
          "description": "语言风格：表达方式特征，如情绪化、碎片化、使用网络黑话等",
          "title": "Behavior Style",
          "type": "string"
        },
        "opportunity_time": {
          "description": "语义时间：对话发生的时间语境特征，如深夜、考试前、开学季等",
          "title": "Opportunity Time",
          "type": "string"
        }
      },
      "required": [
        "intention",
        "cognition",
        "behavior_style",
        "opportunity_time"
      ],
      "title": "ICBOFeatures",
      "type": "object",
      "additionalProperties": false
    },
    "RiskLevel": {
      "description": "风险等级枚举",
      "enum": [
        "High",
        "Medium",
        "Low"
      ],
      "title": "RiskLevel",
      "type": "string"
    },
    "TrendPoint": {
      "properties": {
        "session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session Id"
        },
        "session_time": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session Time"
        },
        "minor_confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Minor Confidence",
          "type": "number"
        }
      },
      "required": [
        "minor_confidence"
      ],
      "title": "TrendPoint",
      "type": "object",
      "additionalProperties": false
    }
  },
  "properties": {
    "decision": {
      "$ref": "#/$defs/FormalDecision"
    },
    "user_profile": {
      "$ref": "#/$defs/FormalUserProfile"
    },
    "icbo_features": {
      "$ref": "#/$defs/ICBOFeatures"
    },
    "evidence": {
      "$ref": "#/$defs/FormalEvidence"
    },
    "reasoning_summary": {
      "title": "Reasoning Summary",
      "type": "string"
    },
    "trend": {
      "$ref": "#/$defs/FormalTrend"
    },
    "uncertainty_notes": {
      "items": {
        "type": "string"
      },
      "title": "Uncertainty Notes",
      "type": "array"
    },
    "recommended_next_step": {
      "default": "collect_more_context",
      "title": "Recommended Next Step",
      "type": "string"
    }
  },
  "required": [
    "decision",
    "user_profile",
    "icbo_features",
    "evidence",
    "reasoning_summary",
    "trend"
  ],
  "title": "FormalSkillOutput",
  "type": "object",
  "additionalProperties": false
}